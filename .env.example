# Acquisitions Deal Platform — copy to `.env`.
# First boot needs NO API key: keep LLM_MOCK=true so agent activities are stubbed.
# Set a real key and LLM_MOCK=false only when you want live matching/agents.

LLM_MOCK=true
ANTHROPIC_API_KEY=

POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=deals

# Synthetic data (make seed) — deterministic by SEED.
SEED=42
SEED_MANDATES=20
SEED_LISTINGS=100
